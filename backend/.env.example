# Database
# Local example for running the backend on your host machine with Postgres on localhost.
# For Supabase, keep the same scheme and include sslmode=require.
# Example:
# DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/flight_data_scrapper
# Auth (Required)
# Generate a real secret: openssl rand -hex 32
JWT_SECRET_KEY=REPLACE-WITH-OUTPUT-OF-openssl-rand-hex-32
ADMIN_EMAIL=admin@example.com
# Must be at least 12 characters. Never commit a real password.
ADMIN_PASSWORD=REPLACE-WITH-A-UNIQUE-ADMIN-PASSWORD
ADMIN_FULL_NAME=System Admin

# App
DEBUG=false
# For local dev: http://localhost:5173
# For production on Vercel, list each Vercel domain here. CORS_ORIGIN_REGEX
# additionally allows any *.vercel.app preview by default.
CORS_ORIGINS=["http://localhost:5173"]
# Regex used as a fallback for CORS and defaults to https://*.vercel.app.
# Override only if you host the frontend somewhere else.
# CORS_ORIGIN_REGEX=^https://([a-z0-9-]+\.)*vercel\.app$
# IMPORTANT: keep the Render wildcard or the exact Render host in this list when you deploy.
ALLOWED_HOSTS=["localhost","127.0.0.1","*.onrender.com","*.vercel.app"]

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=60

# Flight Data Providers
#
# --- ScrapingBee (production provider) ---
# Use ScrapingBee's rendered HTML API to scrape live KAYAK flight result pages.
# Docs: https://www.scrapingbee.com/documentation/
SCRAPINGBEE_API_KEY=YOUR_SCRAPINGBEE_API_KEY_HERE
# Optional key pool for failover. Accepts comma-separated values or a JSON array.
SCRAPINGBEE_API_KEYS=
SCRAPINGBEE_BASE_URL=https://app.scrapingbee.com/api/v1
SCRAPINGBEE_COUNTRY_CODE=us
SCRAPINGBEE_USER_AGENT=flight-harvester/1.0
SCRAPINGBEE_PREMIUM_PROXY=false
SCRAPINGBEE_STEALTH_PROXY=false
SCRAPINGBEE_MULTI_CITY_DEBUG=false

# --- Legacy provider settings ---
# Production collection is ScrapingBee-only. Leave these empty.
KAYAK_API_KEY=
KAYAK_BASE_URL=https://sandbox-en-us.kayakaffiliates.com
KAYAK_POLL_TIMEOUT_SECONDS=90
KAYAK_POLL_INTERVAL_SECONDS=2.0
KAYAK_USER_AGENT=flight-harvester/1.0
KAYAK_ORIGINAL_CLIENT_IP=
SEARCHAPI_KEY=
SEARCHAPI_KEYS=

# Scraping tuning
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=525600
# SCRAPE_BATCH_SIZE=1
# SCRAPE_ROUTE_PARALLELISM=3
# SCRAPE_DELAY_SECONDS=1.0
# PROVIDER_TIMEOUT_SECONDS=60
# PROVIDER_MAX_RETRIES=1
# PROVIDER_CONCURRENCY_LIMIT=3
# PROVIDER_RENDERED_CONCURRENCY_LIMIT=1
# PROVIDER_MIN_DELAY_SECONDS=1.0
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
SCRAPE_RATE_LIMIT_ATTEMPTS=3
SCRAPE_RATE_LIMIT_WINDOW_SECONDS=300

# Monitoring (optional)
SENTRY_DSN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
