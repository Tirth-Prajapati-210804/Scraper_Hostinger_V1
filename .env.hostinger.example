DB_PASSWORD=replace-with-strong-database-password
POSTGRES_DB=flight_data_scrapper
POSTGRES_USER=postgres

# Set these to your real domains after DNS is configured.
CORS_ORIGINS=https://your-frontend-domain.com
ALLOWED_HOSTS=your-api-domain.com

# Required backend secrets.
# Generate JWT_SECRET_KEY with: openssl rand -hex 32
JWT_SECRET_KEY=replace-with-output-of-openssl-rand-hex-32
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-unique-admin-password
ADMIN_FULL_NAME=System Admin

# Keep scheduler enabled on the VPS unless you want manual-only collection.
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=60

# ScrapingBee is the only production provider. It scrapes live KAYAK pages.
# Leave SCRAPINGBEE_COUNTRY_CODE blank so each route group's market drives the KAYAK host.
SCRAPINGBEE_API_KEY=replace-with-scrapingbee-api-key
SCRAPINGBEE_API_KEYS=
SCRAPINGBEE_COUNTRY_CODE=
SCRAPINGBEE_PREMIUM_PROXY=false
SCRAPINGBEE_STEALTH_PROXY=false
SCRAPINGBEE_MULTI_CITY_DEBUG=false

# Conservative first-run VPS tuning.
PROVIDER_TIMEOUT_SECONDS=60
PROVIDER_MAX_RETRIES=1
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=525600
PROVIDER_CONCURRENCY_LIMIT=3
# Keep rendered same-airline Kayak jobs serialized unless you have real
# evidence the provider can sustain more.
PROVIDER_RENDERED_CONCURRENCY_LIMIT=1
PROVIDER_MIN_DELAY_SECONDS=1.0
SCRAPE_BATCH_SIZE=1
SCRAPE_ROUTE_PARALLELISM=3
SCRAPE_DELAY_SECONDS=1.0
